# ================================================================
# TelemetryFlow Hermes — Environment Configuration
# Copy to ~/.hermes/.env and fill in your values
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ================================================================

# ================================================================
# TelemetryFlow Platform Authentication (REQUIRED — pick one method)
# ================================================================
#
# Method A: API Key (recommended for agents)
#   - Create via TelemetryFlow UI: Settings > API Keys > Generate
#   - Format: tfs_<64 alphanumeric chars>
#   - Scopes: llm:chat, llm:read, llm:write, llm:insights, telemetry:read
#   - Set as TELEMETRYFLOW_API_KEY below
#
# Method B: JWT Login (user-scoped, tokens expire)
#   - Set TELEMETRYFLOW_AUTH_EMAIL + TELEMETRYFLOW_AUTH_PASSWORD
#   - Hermes will call POST /api/v2/auth/login to obtain JWT
#   - Token contains: sub, email, roles, permissions, tenantId, organizationId
#   - Expiry: 15m (prod) / 24h (dev)
#
# Method C: Ingestion Headers (for OTEL Collector agents)
#   - Set TELEMETRYFLOW_KEY_ID + TELEMETRYFLOW_KEY_SECRET
#   - Sent as X-TelemetryFlow-Key-ID / X-TelemetryFlow-Key-Secret headers

# ── Method A: API Key (used by _shared.py get_api_key()) ──
TELEMETRYFLOW_API_KEY=

# ── Method B: JWT Login ──
TELEMETRYFLOW_AUTH_EMAIL=
TELEMETRYFLOW_AUTH_PASSWORD=

# ── Method C: Ingestion Headers ──
TELEMETRYFLOW_KEY_ID=
TELEMETRYFLOW_KEY_SECRET=

# ================================================================
# TelemetryFlow Platform Connection (REQUIRED)
# ================================================================

# TelemetryFlow API base URL
# Default: http://localhost:3000/api/v2
TELEMETRYFLOW_API_URL=http://localhost:3000/api/v2

# Organization ID (REQUIRED for all LLM endpoints)
# Every LLM API call is scoped to an organization.
# Find yours: TelemetryFlow UI > Settings > Organization > Copy ID
TELEMETRYFLOW_ORGANIZATION_ID=

# Workspace ID (REQUIRED for telemetry queries)
# ClickHouse queries are scoped to a workspace.
# Find yours: TelemetryFlow UI > Settings > Workspace > Copy ID
TELEMETRYFLOW_WORKSPACE_ID=

# Tenant ID (optional, for multi-tenant setups)
TELEMETRYFLOW_TENANT_ID=

# Default LLM Provider ID (optional)
# If set, Hermes uses this provider instead of the org default.
# Find via: GET /api/v2/llm/providers
TELEMETRYFLOW_DEFAULT_PROVIDER_ID=

# ================================================================
# LLM Provider Keys (for Hermes agent LLM calls)
# ================================================================
# These are used by Hermes profiles, NOT stored in TelemetryFlow.
# TelemetryFlow stores its own provider keys via EncryptionService (AES-256-GCM).
#
# Agent model assignments:
#   Triage       → zhipu/glm-5.1         (cost-efficient)
#   Investigator → anthropic/claude-sonnet-4-5 (complex reasoning)
#   Reviewer     → zhipu/glm-5.1         (cost-efficient)
#   Remediator   → zhipu/glm-5.1         (cost-efficient)
# ================================================================

# Anthropic — recommended for Investigator (complex reasoning)
ANTHROPIC_API_KEY=

# OpenAI — alternative for Investigator
OPENAI_API_KEY=

# Google Gemini — optional for multimodal tasks
GOOGLE_API_KEY=

# DeepSeek — cost-efficient alternative
DEEPSEEK_API_KEY=

# Qwen (Alibaba) — alternative provider
QWEN_API_KEY=

# Mistral — European data-residency
MISTRAL_API_KEY=

# Grok (xAI) — alternative provider
GROK_API_KEY=

# Kimi (Moonshot) — alternative provider
KIMI_API_KEY=

# Zhipu (GLM) — Triage/Reviewer/Remediator default
ZHIPU_API_KEY=

# MiMo (Xiaomi) — alternative provider
MIMO_API_KEY=

# OpenRouter — unified endpoint for 200+ models
OPENROUTER_API_KEY=

# Ollama — air-gapped / local models (no key needed)
# Ensure Ollama is running: http://localhost:11434

# ================================================================
# LLM Encryption Key (for TelemetryFlow provider key management)
# ================================================================
# Only needed if using manage_provider tool to create/update
# LLM providers via the TelemetryFlow API. Must be >= 32 characters.
# TelemetryFlow's EncryptionService uses this for AES-256-GCM encryption.
LLM_ENCRYPTION_KEY=

# ================================================================
# ClickHouse Connection (read-only Hermes user)
# ================================================================
# NOTE: Hermes tools query ClickHouse through the TelemetryFlow API
# (/telemetry/query), NOT directly. These are only used by
# direct query tools or debugging scripts.
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=hermes_readonly
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=telemetryflow

# ================================================================
# Kubernetes
# ================================================================
KUBECONFIG=~/.kube/config

# ================================================================
# Telegram Gateway (per-profile bot tokens)
# Each agent needs its own bot (Telegram allows 1 connection per token)
# ================================================================
TELEGRAM_BOT_TOKEN_TRIAGE=
TELEGRAM_CHAT_ID_TRIAGE=
TELEGRAM_BOT_TOKEN_INVESTIGATOR=
TELEGRAM_CHAT_ID_INVESTIGATOR=
TELEGRAM_BOT_TOKEN_REVIEWER=
TELEGRAM_CHAT_ID_REVIEWER=
TELEGRAM_BOT_TOKEN_REMEDIATOR=
TELEGRAM_CHAT_ID_REMEDIATOR=

# ================================================================
# Optional: TelemetryFlow Platform Backend (for direct deployment)
# ================================================================
# These are NOT needed for Hermes agent operation.
# Only set if you're also running the TelemetryFlow Platform backend.

# JWT_SECRET=               # Min 32 chars. Signs JWT access tokens.
# JWT_REFRESH_SECRET=       # Min 32 chars. Signs JWT refresh tokens.
# JWT_ACCESS_EXPIRY=15m     # Access token TTL
# JWT_REFRESH_EXPIRY=7d     # Refresh token TTL
# SESSION_SECRET=           # Min 32 chars. Cookie signing.
# ENCRYPTION_KEY=           # Min 32 chars. General encryption.
# MFA_ENCRYPTION_KEY=       # Min 32 chars. TOTP secret encryption.
# LLM_DEFAULT_RATE_LIMIT=100  # Requests/min per org
# DEFAULT_ORGANIZATION_ID=  # Fallback org ID for org-resolver
# POSTGRES_HOST=            # TypeORM connection
# POSTGRES_PORT=5432
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=telemetryflow
# REDIS_HOST=localhost
# REDIS_PORT=6379
# PORT=3000
